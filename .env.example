# CodeReview Arena runs with no credentials. The control and reference-patch
# reviewers are fully deterministic; benchmark a real model by wiring it through
# the custom-command reviewer (see README).

# Where the SQLite run database and run artifacts are written.
ARENA_DB_PATH=arena.db
ARENA_RUNS_DIR=runs

# Base URL the dashboard uses to reach the `arena serve` API.
ARENA_API_URL=http://localhost:8000
